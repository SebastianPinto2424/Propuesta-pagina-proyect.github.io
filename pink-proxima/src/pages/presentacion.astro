---
import PlantillaBase from '../layouts/PlantillaBase.astro';
import EncabezadoSitio from '../components/sitio/EncabezadoSitio.astro';
import PieSitio from '../components/sitio/PieSitio.astro';
import '../styles/propuesta.css';

const enlacePropuesta = `${import.meta.env.BASE_URL}`;
---

<PlantillaBase
  titulo="UBBike | Producto"
  descripcion="Apartado reservado para la presentación oficial del producto UBBike cuando la app esté funcional."
>
  <EncabezadoSitio vistaActual="presentacion" mostrarNavegacionSecciones={false} />

  <main id="inicio">
    <section class="hero container">
      <p class="eyebrow">Apartado en preparación</p>
      <h1>Producto UBBike</h1>
      <p class="lead">
        Este espacio queda reservado para la presentación oficial de la aplicación una vez que el
        desarrollo funcional esté completado.
      </p>

      <div class="grid two section-gap">
        <article class="card">
          <h3>Estado actual</h3>
          <p>
            En desarrollo. Se incorporarán capturas reales de la app, demo de flujo, arquitectura
            técnica y resultados de validación.
          </p>
        </article>
        <article class="card">
          <h3>Contenido planificado</h3>
          <ul>
            <li>Presentación del producto final UBBike.</li>
            <li>Funciones implementadas y evidencias de uso.</li>
            <li>Indicadores de desempeño y mejoras alcanzadas.</li>
            <li>Próximos pasos y crecimiento por etapas.</li>
          </ul>
        </article>
      </div>

      <div class="hero-actions">
        <a class="btn btn-primary" href={enlacePropuesta}>Ir a la propuesta</a>
      </div>
    </section>
  </main>

  <PieSitio />
</PlantillaBase>
