---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'BiciUBB Control | Propuesta de Proyecto',
  description = 'Aplicacion multiplataforma para control y trazabilidad del ingreso y retiro de bicicletas en los bicicleteros de la Universidad del Bio-Bio.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #f4f7fb;
    --surface: #ffffff;
    --ink: #111827;
    --muted: #4b5563;
    --primary: #0b4b6f;
    --primary-strong: #06344e;
    --accent: #199a8e;
    --line: #d7deea;
    --shadow: 0 14px 40px rgb(8 36 60 / 10%);
    --radius: 18px;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    min-height: 100%;
    background:
      radial-gradient(1200px 520px at 86% -10%, rgb(25 154 142 / 18%), transparent),
      radial-gradient(900px 400px at -10% 10%, rgb(11 75 111 / 16%), transparent),
      var(--bg);
    color: var(--ink);
    font-family: 'Segoe UI', 'Aptos', 'Helvetica Neue', Arial, sans-serif;
    line-height: 1.55;
    scroll-behavior: smooth;
  }

  a {
    color: inherit;
  }

  .container {
    width: min(1120px, 92%);
    margin-inline: auto;
  }
</style>
